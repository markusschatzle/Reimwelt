# Canonical public origin (used for metadata, sitemap, robots).
NEXT_PUBLIC_SITE_URL=https://reimwelt.de

# Server-side base URL the Next.js server uses to reach FastAPI (SSR + rewrites).
INTERNAL_API_URL=http://127.0.0.1:8000

# How many top-frequency words per language to pre-generate at build time.
# The rest are produced on first request via ISR (dynamicParams=true).
SSG_WORD_LIMIT=1000

# How many of the most common word endings per language to pre-generate.
SSG_ENDING_LIMIT=200

# Optional Google tags (client-side). Leave empty for local dev.
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_ADS_ID=
